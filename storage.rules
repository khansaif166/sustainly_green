rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    match /{allPaths=**} {
      // By default, only allow authenticated users to read.
      // Adjust this based on whether you want certificates public.
      allow read: if true;
    }

    match /vendors/{userId}/{allPaths=**} {
      // Allow users to upload to their own vendor folder
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
